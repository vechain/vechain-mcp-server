{
  "name": "@vechain/mcp-server",
  "version": "2.0.2",
  "type": "module",
  "author": "VeChain Foundation",
  "license": "MIT",
  "main": "./dist/stdio.js",
  "bin": {
    "vechain-mcp-server": "./dist/stdio.js"
  },
  "homepage": "https://github.com/vechain/vechain-mcp-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vechain/vechain-mcp-server.git"
  },
  "keywords": [
    "VeChain",
    "MCP",
    "server"
  ],
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "LOG_LEVEL=0 PORT=4000 MCP_AUTH_DISABLED=true tsx --watch src/http.ts",
    "start": "node dist/http.js",
    "format": "biome format --write",
    "lint": "biome lint --write",
    "inspect": "DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector npm run dev",
    "inspect:stdio": "DANGEROUSLY_OMIT_AUTH=true npx @modelcontextprotocol/inspector npx tsx src/stdio.ts",
    "pretest": "npm run build",
    "test": "start-server-and-test 'PORT=4000 MCP_AUTH_DISABLED=true node dist/http.js' http-get://localhost:4000/ready 'jest --config jest.config.js --runInBand'"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@vechain/sdk-core": "^2.0.5",
    "@vechain/sdk-network": "^2.0.5",
    "@vechain/vebetterdao-contracts": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "8.1.0",
    "tslog": "^4.10.2",
    "viem": "^2.38.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.7",
    "@modelcontextprotocol/inspector": "^0.17.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.9.1",
    "jest": "^30.2.0",
    "start-server-and-test": "^2.1.2",
    "ts-jest": "^29.4.5",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "qs": "6.14.1",
    "minimatch": "^9.0.7",
    "serialize-javascript": "^7.0.3",
    "undici": "^6.24.0",
    "glob": "^10.4.5",
    "rimraf": "^5.0.10",
    "uuid": "^11.1.0"
  }
}
